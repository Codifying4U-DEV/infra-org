{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "paths": {
      "@/config/*": ["./config/*"],
      "@/lib/*": ["./lib/*"],
      "@/modules/*": ["./modules/*"],
      "@/types/*": ["./types/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "index.ts",
    "config/**/*.ts",
    "lib/**/*.ts",
    "modules/**/*.ts",
    "types/**/*.d.ts"
  ]
}
